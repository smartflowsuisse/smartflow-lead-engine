# AI Website Analysis (disabled by default)
AI_ANALYSIS_ENABLED=false

# Provider: openai | anthropic
AI_PROVIDER=openai

# API keys (optional until AI is enabled)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# Model selection
AI_MODEL=gpt-4o-mini

# Request limits
AI_REQUEST_TIMEOUT_MS=25000
AI_MAX_HTML_EXCERPT_CHARS=8000
AI_MAX_QUICK_WINS=8
AI_MAX_AUTOMATION_OPS=6
